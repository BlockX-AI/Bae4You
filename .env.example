# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (Railway injects DATABASE_URL automatically) ────
DATABASE_URL=postgresql://postgres:password@localhost:5432/bae4u

# ── Redis (Railway injects REDIS_URL automatically) ──────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_another_64_char_random_hex
SIWE_DOMAIN=localhost

# ── Blockchain (Base Sepolia testnet) ─────────────────────────
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# The wallet that deploys contracts (needs Base Sepolia ETH from faucet)
DEPLOYER_PRIVATE_KEY=0x_your_deployer_wallet_private_key

# A SEPARATE wallet just for signing EIP-712 bonus/badge claims
# This wallet holds NO ETH and has NO contract owner powers
SIGNER_PRIVATE_KEY=0x_your_signer_wallet_private_key

# Filled in AFTER running: pnpm deploy:contracts
PETS_CASH_ADDRESS=0x
PETS_REGISTRY_ADDRESS=0x
PETS_MARKET_ADDRESS=0x
PETS_RANKING_ADDRESS=0x

CHAIN_ID=84532
BASESCAN_API_KEY=your_basescan_api_key

# ── The Graph ─────────────────────────────────────────────────
GRAPH_API_URL=https://api.thegraph.com/subgraphs/name/bae4u/pets

# ── Fiat On/Off-Ramp ──────────────────────────────────────────
TRANSAK_API_KEY=your_transak_api_key
TRANSAK_SECRET=your_transak_webhook_secret
MOONPAY_API_KEY=your_moonpay_api_key

# ── Pinecone (matching algorithm) ─────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=bae4u-personalities

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=https://your@sentry.io/project
MIXPANEL_TOKEN=your_mixpanel_token

# ── Game Config ───────────────────────────────────────────────
# PetsCash amount minted per login bonus claim (18 decimals)
BONUS_AMOUNT_PCASH=100000000000000000000
# Starting price for new user pet in PetsCash (18 decimals)  
STARTING_PRICE_PCASH=1000000000000000000000
